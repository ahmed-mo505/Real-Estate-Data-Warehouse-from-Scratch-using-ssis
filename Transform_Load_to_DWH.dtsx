            <component
              refId="Package\DFT_Fact_PropertySales\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    t.transaction_id,
    CAST(t.property_id    AS INT)     AS property_id,
    CAST(t.agent_id       AS INT)     AS agent_id,
    t.transaction_type,
    TRY_CAST(t.sale_price_local AS FLOAT) AS sale_price_local,
    t.currency_code,
    TRY_CAST(t.commission_pct    AS FLOAT) AS commission_pct,
    TRY_CAST(t.commission_amount AS FLOAT) AS commission_amount,
    TRY_CONVERT(DATE, REPLACE(t.transaction_date, '/', '-')) AS transaction_date,
    t.buyer_nationality,
    CASE
        WHEN UPPER(TRIM(t.payment_method)) = 'BANK TRANSFER' THEN 'Bank Transfer'
        WHEN UPPER(TRIM(t.payment_method)) = 'INSTALMENT'    THEN 'Installment'
        ELSE TRIM(t.payment_method)
    END                               AS payment_method,
    LEFT(TRIM(t.country_code), 2)     AS country_code,
    LEFT(TRIM(t.currency_code), 3)    AS currency_code_clean,

    -- من STG_Listings عشان نجيب listing_date و city و size_sqm
    TRY_CONVERT(DATE, REPLACE(l.listing_date, '/', '-')) AS listing_date,
    TRY_CAST(l.size_sqm AS FLOAT)     AS size_sqm,
    l.city,

    -- حساب days_on_market هنا في الـ SQL
    DATEDIFF(DAY,
        TRY_CONVERT(DATE, REPLACE(l.listing_date,     '/', '-')),
        TRY_CONVERT(DATE, REPLACE(t.transaction_date, '/', '-'))
    )                                 AS days_on_market

FROM STG.STG_Transactions t
INNER JOIN STG.STG_Listings l
    ON CAST(t.property_id AS INT) = CAST(l.property_id AS INT)
WHERE t.transaction_id  IS NOT NULL
  AND t.property_id     IS NOT NULL
  AND t.transaction_date IS NOT NULL
  AND t.transaction_date != ''</property>
