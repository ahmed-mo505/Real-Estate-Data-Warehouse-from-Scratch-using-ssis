                              name="Expression">[UPPER]([TRIM](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[property_type]})) == "APARTMNT" ? "Apartment" : [UPPER]([TRIM](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[property_type]})) == "VLLA" ? "Villa" : [UPPER]([TRIM](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[property_type]})) == "AVAILBLE" ? "Apartment" : [TRIM](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[property_type]})</property>
