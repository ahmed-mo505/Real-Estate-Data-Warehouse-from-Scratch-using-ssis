            <component
              refId="Package\DFT_Fact_PropertySales\Conditional Split"
              componentClassID="Microsoft.ConditionalSplit"
              contactInfo="Conditional Split;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;0"
              description="Routes data rows to different outputs depending on the content of the data. Use conditions (SSIS expressions) to specify which rows are routed. For example, separate records that need to be cleaned from those that are ready to be loaded or route only a subset of records."
              name="Conditional Split"
              usesDispositions="true">
              <inputs>
                <input
                  refId="Package\DFT_Fact_PropertySales\Conditional Split.Inputs[Conditional Split Input]"
                  description="Input to the Conditional Split Transformation"
                  name="Conditional Split Input">
                  <inputColumns>
                    <inputColumn
                      refId="Package\DFT_Fact_PropertySales\Conditional Split.Inputs[Conditional Split Input].Columns[sale_price_local]"
                      cachedDataType="r8"
                      cachedName="sale_price_local"
                      lineageId="Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[sale_price_local]" />
                    <inputColumn
                      refId="Package\DFT_Fact_PropertySales\Conditional Split.Inputs[Conditional Split Input].Columns[commission_pct]"
                      cachedDataType="r8"
                      cachedName="commission_pct"
                      lineageId="Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[commission_pct]" />
                    <inputColumn
