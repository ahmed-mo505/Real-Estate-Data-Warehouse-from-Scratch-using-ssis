                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    property_id,
    property_type,
    city,
    country_code,
    currency_code,
    price_local,
    size_sqm,
    bedrooms,
    bathrooms,
    floor_number,
    year_built,
    amenities,
    listing_date,
    status,
    agent_id,
    ROW_NUMBER() OVER (
        PARTITION BY property_id
        ORDER BY stg_id
    ) AS row_num
FROM STG.STG_Listings
WHERE property_id IS NOT NULL
  AND property_id != ''</property>
