            <component
              refId="Package\DFT_Fact_PropertySales\Derived Column"
              componentClassID="Microsoft.DerivedColumn"
              contactInfo="Derived Column;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;0"
              description="Creates new column values by applying expressions to transformation input columns. Create new columns or overwrite existing ones. For example, concatenate the values from the 'first name' and 'last name' column to make a 'full name' column."
              name="Derived Column"
              usesDispositions="true">
              <inputs>
                <input
                  refId="Package\DFT_Fact_PropertySales\Derived Column.Inputs[Derived Column Input]"
                  description="Input to the Derived Column Transformation"
                  name="Derived Column Input">
                  <inputColumns>
                    <inputColumn
                      refId="Package\DFT_Fact_PropertySales\Derived Column.Inputs[Derived Column Input].Columns[sale_price_local]"
                      cachedDataType="r8"
                      cachedName="sale_price_local"
                      lineageId="Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[sale_price_local]" />
                    <inputColumn
                      refId="Package\DFT_Fact_PropertySales\Derived Column.Inputs[Derived Column Input].Columns[listing_date]"
                      cachedDataType="wstr"
                      cachedLength="10"
                      cachedName="listing_date"
                      lineageId="Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]" />
                    <inputColumn
                      refId="Package\DFT_Fact_PropertySales\Derived Column.Inputs[Derived Column Input].Columns[size_sqm]"
                      cachedDataType="r8"
                      cachedName="size_sqm"
                      lineageId="Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[size_sqm]" />
                  </inputColumns>
                  <externalMetadataColumns />
                </input>
              </inputs>
              <outputs>
                <output
                  refId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output]"
                  description="Default Output of the Derived Column Transformation"
                  exclusionGroup="1"
                  name="Derived Column Output"
                  synchronousInputId="Package\DFT_Fact_PropertySales\Derived Column.Inputs[Derived Column Input]">
                  <outputColumns>
                    <outputColumn
                      refId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output].Columns[price_per_sqm]"
                      dataType="numeric"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output].Columns[price_per_sqm]"
                      name="price_per_sqm"
                      precision="18"
                      scale="2"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(#{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[size_sqm]} == 0 || [ISNULL](#{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[size_sqm]})) ? (DT_NUMERIC,18,2)0 : (DT_NUMERIC,18,2)(#{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[sale_price_local]} / #{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[size_sqm]})</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(size_sqm == 0 || ISNULL(size_sqm)) ? (DT_NUMERIC,18,2)0 : (DT_NUMERIC,18,2)(sale_price_local / size_sqm)</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output].Columns[listing_date_key]"
                      dataType="i4"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output].Columns[listing_date_key]"
                      name="listing_date_key"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(DT_I4)([YEAR]((DT_DBDATE)#{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]}) * 10000 + [MONTH]((DT_DBDATE)#{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]}) * 100 + [DAY]((DT_DBDATE)#{Package\DFT_Fact_PropertySales\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]}))</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(DT_I4)(YEAR((DT_DBDATE)listing_date) * 10000 + MONTH((DT_DBDATE)listing_date) * 100 + DAY((DT_DBDATE)listing_date))</property>
                      </properties>
                    </outputColumn>
                    <outputColumn
                      refId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output].Columns[dwh_insert_date]"
                      dataType="dbTimeStamp"
                      errorOrTruncationOperation="Computation"
                      errorRowDisposition="FailComponent"
                      lineageId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Output].Columns[dwh_insert_date]"
                      name="dwh_insert_date"
                      truncationRowDisposition="FailComponent">
                      <properties>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Expression"
                          name="Expression">(DT_DBTIMESTAMP)[GETDATE]()</property>
                        <property
                          containsID="true"
                          dataType="System.String"
                          description="Derived Column Friendly Expression"
                          expressionType="Notify"
                          name="FriendlyExpression">(DT_DBTIMESTAMP)GETDATE()</property>
                      </properties>
                    </outputColumn>
                  </outputColumns>
                  <externalMetadataColumns />
                </output>
                <output
                  refId="Package\DFT_Fact_PropertySales\Derived Column.Outputs[Derived Column Error Output]"
