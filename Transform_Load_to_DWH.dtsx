                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">[ISNULL](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]}) ? (DT_DBDATE)"1900-01-01" : (DT_DBDATE)([SUBSTRING](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]},1,4) + "-" + [SUBSTRING](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]},6,2) + "-" + [SUBSTRING](#{Package\Sequence Container\DFT_Load_DIM_Property\OLE DB Source.Outputs[OLE DB Source Output].Columns[listing_date]},9,2))</property>
