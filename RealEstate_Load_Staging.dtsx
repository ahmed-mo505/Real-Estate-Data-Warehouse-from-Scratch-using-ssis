    <DTS:Executable
      DTS:refId="Package\Execute SQL Task-Create Schema &amp; Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Create Schema &amp; Tables"
      DTS:DTSID="{8FD8B55E-7417-4267-ADA2-D7A5B57B1FE2}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task-Create Schema &amp; Tables"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A922B48F-1209-4854-BC7E-36757135C6EE}"
          SQLTask:SqlStatementSource="-- Schema&#xA;IF NOT EXISTS (&#xA;    SELECT * FROM sys.schemas WHERE name = 'STG'&#xA;)&#xA;EXEC('CREATE SCHEMA STG');&#xA;&#xA;-- STG_Listings&#xA;IF OBJECT_ID('STG.STG_Listings','U') IS NULL&#xA;CREATE TABLE STG.STG_Listings (&#xA;    stg_id          INT IDENTITY(1,1) PRIMARY KEY,&#xA;    load_date       DATETIME         DEFAULT GETDATE(),&#xA;    source_file     NVARCHAR(100)    DEFAULT 'properties_listings.csv',&#xA;    property_id     NVARCHAR(20),&#xA;    property_type   NVARCHAR(50),&#xA;    city            NVARCHAR(100),&#xA;    country_code    NVARCHAR(10),&#xA;    currency_code   NVARCHAR(10),&#xA;    price_local     NVARCHAR(30),&#xA;    size_sqm        NVARCHAR(20),&#xA;    bedrooms        NVARCHAR(10),&#xA;    bathrooms       NVARCHAR(10),&#xA;    floor_number    NVARCHAR(10),&#xA;    year_built      NVARCHAR(10),&#xA;    amenities       NVARCHAR(500),&#xA;    listing_date    NVARCHAR(30),&#xA;    status          NVARCHAR(30),&#xA;    agent_id        NVARCHAR(20)&#xA;);&#xA;&#xA;-- STG_Transactions&#xA;IF OBJECT_ID('STG.STG_Transactions','U') IS NULL&#xA;CREATE TABLE STG.STG_Transactions (&#xA;    stg_id              INT IDENTITY(1,1) PRIMARY KEY,&#xA;    load_date           DATETIME         DEFAULT GETDATE(),&#xA;    source_file         NVARCHAR(100)    DEFAULT 'properties_transactions.csv',&#xA;    transaction_id      NVARCHAR(20),&#xA;    property_id         NVARCHAR(20),&#xA;    agent_id            NVARCHAR(20),&#xA;    transaction_type    NVARCHAR(20),&#xA;    sale_price_local    NVARCHAR(30),&#xA;    currency_code       NVARCHAR(10),&#xA;    commission_pct      NVARCHAR(20),&#xA;    commission_amount   NVARCHAR(30),&#xA;    transaction_date    NVARCHAR(30),&#xA;    buyer_nationality   NVARCHAR(100),&#xA;    payment_method      NVARCHAR(50),&#xA;    country_code        NVARCHAR(10)&#xA;);&#xA;&#xA;-- STG_Agents&#xA;IF OBJECT_ID('STG.STG_Agents','U') IS NULL&#xA;CREATE TABLE STG.STG_Agents (&#xA;    stg_id              INT IDENTITY(1,1) PRIMARY KEY,&#xA;    load_date           DATETIME         DEFAULT GETDATE(),&#xA;    source_file         NVARCHAR(100)    DEFAULT 'agents.txt',&#xA;    agent_id            NVARCHAR(20),&#xA;    agent_name          NVARCHAR(200),&#xA;    agency              NVARCHAR(200),&#xA;    specialization      NVARCHAR(100),&#xA;    country             NVARCHAR(10),&#xA;    phone               NVARCHAR(50),&#xA;    email               NVARCHAR(200),&#xA;    hire_date           NVARCHAR(30),&#xA;    active              NVARCHAR(10),&#xA;    experience_years    NVARCHAR(10)&#xA;);&#xA;&#xA;-- STG_Currency&#xA;IF OBJECT_ID('STG.STG_Currency','U') IS NULL&#xA;CREATE TABLE STG.STG_Currency (&#xA;    stg_id          INT IDENTITY(1,1) PRIMARY KEY,&#xA;    load_date       DATETIME         DEFAULT GETDATE(),&#xA;    source_file     NVARCHAR(100)    DEFAULT 'Exchange Rate API',&#xA;    base_currency   NVARCHAR(10),&#xA;    target_currency NVARCHAR(10),&#xA;    rate_to_base    FLOAT,&#xA;    fetch_date      DATE             DEFAULT CAST(GETDATE() AS DATE)&#xA;);&#xA;&#xA;-- STG_Load_Log&#xA;IF OBJECT_ID('STG.STG_Load_Log','U') IS NULL&#xA;CREATE TABLE STG.STG_Load_Log (&#xA;    log_id          INT IDENTITY(1,1) PRIMARY KEY,&#xA;    package_name    NVARCHAR(200),&#xA;    table_name      NVARCHAR(100),&#xA;    run_start       DATETIME,&#xA;    run_end         DATETIME,&#xA;    rows_loaded     INT,&#xA;    status          NVARCHAR(20),&#xA;    error_message   NVARCHAR(MAX)    NULL&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Execute SQL Task-CreateDB"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="CreateDB"
      DTS:DTSID="{9C6F9F58-7369-4F51-B35F-E9B887095A2D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task-CreateDB"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{33D3359C-8A11-4A01-83EF-60D7468D1692}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (&#xA;    SELECT name FROM sys.databases &#xA;    WHERE name = 'RealEstate_Staging'&#xA;)&#xA;BEGIN&#xA;    CREATE DATABASE RealEstate_Staging;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
